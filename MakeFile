CC     = gcc
CFLAGS = -Wall -Wextra -Iinclude
SRC    = src/main.c src/auth.c src/student.c \
         src/assessment.c src/prediction.c   \
         src/gap_analysis.c src/file_handler.c \
         src/report.c src/ui.c

all: career_system

career_system: $(SRC)
	$(CC) $(CFLAGS) $(SRC) -o career_system

clean:
	rm -f career_system